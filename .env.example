# Root environment for docker-compose. Copy to .env and edit before deploying.

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory

# --- Backend ---
# Long random string in production (e.g. `openssl rand -hex 32`).
SECRET_KEY=change-me-in-production
ADMIN_EMAIL=admin@inventorypro.com
ADMIN_PASSWORD=admin123
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Frontend (build-time) ---
# Must point to the publicly reachable backend URL in production.
VITE_API_URL=http://localhost:8000
