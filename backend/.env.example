# Backend configuration — copy to .env and adjust. Never commit real secrets.

# SQLAlchemy / PostgreSQL connection string.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/inventory

# Mock-login admin credentials (change these).
ADMIN_EMAIL=admin@inventorypro.com
ADMIN_PASSWORD=admin123

# JWT signing — set a long random value in production.
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Inventory defaults
DEFAULT_LOW_STOCK_THRESHOLD=10

# Keep-alive scheduler — pings an endpoint every N seconds so free hosts
# (Render/Railway/Fly) don't sleep the service. In production set KEEPALIVE_URL
# to the PUBLIC health URL so it generates external traffic.
KEEPALIVE_ENABLED=true
KEEPALIVE_INTERVAL_SECONDS=40
KEEPALIVE_URL=
